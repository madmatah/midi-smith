#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd -- "${script_dir}/.." && pwd)"

cd "${repo_root}"

if command -v python3 >/dev/null 2>&1; then
    exec python3 -m tools.rtt_scope_app "$@"
fi

exec python -m tools.rtt_scope_app "$@"
