{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "ADC: configure+build Debug",
      "type": "shell",
      "command": "cmake --preset adc-Debug && cmake --build --preset adc-Debug --target adc-board",
      "group": "build",
      "problemMatcher": "$gcc"
    },
    {
      "label": "ADC: configure+build Release",
      "type": "shell",
      "command": "cmake --preset adc-Release && cmake --build --preset adc-Release --target adc-board",
      "group": "build",
      "problemMatcher": "$gcc"
    },
    {
      "label": "Main: configure+build Debug",
      "type": "shell",
      "command": "cmake --preset main-Debug && cmake --build --preset main-Debug --target main-board",
      "group": "build",
      "problemMatcher": "$gcc"
    },
    {
      "label": "Main: configure+build Release",
      "type": "shell",
      "command": "cmake --preset main-Release && cmake --build --preset main-Release --target main-board",
      "group": "build",
      "problemMatcher": "$gcc"
    },
    {
      "label": "Host: configure+build tests",
      "type": "shell",
      "command": "cmake --preset Host-Debug && cmake --build --preset Host-Debug --target all",
      "group": "build",
      "problemMatcher": "$gcc"
    },
    {
      "label": "Host: run tests",
      "type": "shell",
      "command": "cmake --preset Host-Debug && ctest --preset Host-Debug --output-on-failure",
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "CMake: format",
      "type": "shell",
      "command": "cmake --build --preset Host-Debug --target format",
      "group": "build",
      "problemMatcher": [],
      "detail": "Format code"
    },
    {
      "label": "CMake: lint",
      "type": "shell",
      "command": "cmake --build --preset Host-Debug --target lint",
      "group": "build",
      "problemMatcher": [],
      "detail": "Lint code"
    }
  ]
}
