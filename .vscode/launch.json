{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug adc-board",
      "type": "cortex-debug",
      "request": "launch",
      "servertype": "openocd",
      "openOCDPreConfigLaunchCommands": [
        "if {[info exists env(MIDISMITH_STLINK_SERIAL_ADC)]} { adapter serial $env(MIDISMITH_STLINK_SERIAL_ADC) }",
        "if {\"${config:midismith.stlinkSerialAdc}\" != \"\"} { adapter serial \"${config:midismith.stlinkSerialAdc}\" }"
      ],
      "configFiles": [
        "interface/stlink.cfg",
        "target/stm32h7x.cfg",
        "${workspaceFolder}/.vscode/openocd-gdb-detach-resume.cfg"
      ],
      "cwd": "${workspaceFolder}",
      "executable": "${workspaceFolder}/build/adc-Debug/firmwares/adc-board/adc-board.elf",
      "device": "STM32H743ZITx",
      "svdFile": "${workspaceFolder}/firmwares/adc-board/hardware/svd/STM32H743.svd",
      "runToEntryPoint": "main",
      "rttConfig": {
        "enabled": true,
        "address": "auto",
        "polling_interval": 10,
        "rtt_start_retry": 1000,
        "clearSearch": true,
        "decoders": [
          {
            "port": 0,
            "type": "console",
            "label": "RTT"
          },
          {
            "port": 1,
            "type": "graph",
            "encoding": "unsigned",
            "graphId": "sensor",
            "label": "Sensor"
          }
        ]
      },
      "preLaunchTask": "ADC: configure+build Debug"
    },
    {
      "name": "Debug main-board",
      "type": "cortex-debug",
      "request": "launch",
      "servertype": "openocd",
      "openOCDPreConfigLaunchCommands": [
        "if {[info exists env(MIDISMITH_STLINK_SERIAL_MAIN)]} { adapter serial $env(MIDISMITH_STLINK_SERIAL_MAIN) }",
        "if {\"${config:midismith.stlinkSerialMain}\" != \"\"} { adapter serial \"${config:midismith.stlinkSerialMain}\" }"
      ],
      "configFiles": [
        "interface/stlink.cfg",
        "target/stm32h7x.cfg",
        "${workspaceFolder}/.vscode/openocd-gdb-detach-resume.cfg"
      ],
      "cwd": "${workspaceFolder}",
      "executable": "${workspaceFolder}/build/main-Debug/firmwares/main-board/main-board.elf",
      "device": "STM32H7B0VBTx",
      "svdFile": "${workspaceFolder}/firmwares/main-board/Hardware/svd/STM32H7B0.svd",
      "runToEntryPoint": "main",
      "rttConfig": {
        "enabled": true,
        "address": "auto",
        "polling_interval": 10,
        "rtt_start_retry": 1000,
        "clearSearch": true,
        "decoders": [
          {
            "port": 0,
            "type": "console",
            "label": "RTT"
          },
          {
            "port": 1,
            "type": "graph",
            "encoding": "unsigned",
            "graphId": "led_state",
            "label": "LED state"
          }
        ]
      },
      "preLaunchTask": "Main: configure+build Debug"
    }
  ]
}
